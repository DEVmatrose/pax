# PAX Festival - Nextcloud API Konfiguration
# WICHTIG: Diese Datei nach .env kopieren und mit echten Werten füllen!

# Nextcloud Server URL (ohne trailing slash)
NEXTCLOUD_URL=https://deine-nextcloud-instanz.de

# Nextcloud API Credentials
NEXTCLOUD_USERNAME=dein-benutzername
NEXTCLOUD_PASSWORD=dein-app-passwort

# Nextcloud Tabellen-IDs (Tables App)
# Diese IDs bekommst du nach dem Erstellen der Tabellen in Nextcloud
TABLE_ID_MUSIKER=
TABLE_ID_WORKSHOPS=
TABLE_ID_VORTRAEGE=
TABLE_ID_AUSSTELLER=

# Optional: Cache-Zeit in Minuten (Standard: 15)
CACHE_DURATION=15
